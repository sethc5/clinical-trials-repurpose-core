# ──────────────────────────────────────────────────────────────────────────
# clinical-trial-repurposing-pipeline-core — environment variables
#
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────

# ── LLM (required for T1 evidence extraction and T2 synthesis) ────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── PubMed / NCBI (strongly recommended; raises rate limit 3×) ───────────
NCBI_EMAIL=your@email.com
PUBMED_API_KEY=                  # From https://www.ncbi.nlm.nih.gov/account/

# ── DrugBank ──────────────────────────────────────────────────────────────
# Academic/commercial API key from https://drugbank.com/
DRUGBANK_API_KEY=

# ── DisGeNET ──────────────────────────────────────────────────────────────
# Free academic key from https://www.disgenet.com/
DISGENET_API_KEY=

# ── OMIM ──────────────────────────────────────────────────────────────────
# Request from https://www.omim.org/api
OMIM_API_KEY=

# ── LINCS L1000 / clue.io ─────────────────────────────────────────────────
# Free registration at https://clue.io/
LINCS_API_KEY=

# ── Open Targets (no key required for public GraphQL endpoint) ────────────
# OPENTARGETS_API_URL=https://api.platform.opentargets.org/api/v4/graphql

# ── STRING PPI (no key required; higher rate limit with registration) ─────
# STRING_IDENTIFIER=your@email.com

# ── Orphanet (data download; no key required) ─────────────────────────────
# ORPHANET_XML_PATH=reference/orphanet_en_product6.xml

# ── Optional: proxy / network ────────────────────────────────────────────
# HTTP_PROXY=
# HTTPS_PROXY=
